# Puerto donde corre nuestro proxy (el que usarás para hacer peticiones)
PROXY_PORT=3000

# Puerto donde corre opencode serve internamente (no cambiar salvo conflicto)
OPENCODE_PORT=4096

# Hostname de opencode serve (no cambiar)
OPENCODE_HOST=127.0.0.1

# Modelo a usar. Dejar vacío para auto-detectar el modelo default de tu cuenta.
# Con ChatGPT Pro los modelos son GPT-5 series: openai/gpt-5.4, openai/gpt-5.2, etc.
DEFAULT_MODEL=openai/gpt-5.4

# (Opcional) Token de seguridad para proteger tu endpoint local
# Si lo configuras, debes enviarlo en el header: Authorization: Bearer <token>
# API_SECRET=tu_token_secreto_aqui

# Configuración de correo de alerta (se envía cuando las credenciales de ChatGPT expiran)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=programacion@h2oins.com
SMTP_PASS=lqyl mblu ciit zcwb
ALERT_EMAIL_TO=programacion@h2oins.com
