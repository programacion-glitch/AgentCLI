# Puerto donde corre nuestro proxy (el que usarás para hacer peticiones)
PROXY_PORT=3000

# Puerto donde corre opencode serve internamente (no cambiar salvo conflicto)
OPENCODE_PORT=4096

# Hostname de opencode serve (no cambiar)
OPENCODE_HOST=127.0.0.1

# Modelo a usar. Si tienes ChatGPT Pro, los modelos disponibles son GPT-5 series.
# Deja vacío para que el proxy detecte automáticamente el modelo default de tu cuenta.
# Ejemplos con ChatGPT Pro: openai/gpt-5.4, openai/gpt-5.2, openai/gpt-5.1-codex
# Ejemplos con API Key: openai/gpt-4o, openai/gpt-4o-mini
DEFAULT_MODEL=

# (Opcional) Token de seguridad para proteger tu endpoint local
# Si lo configuras, debes enviarlo en el header: Authorization: Bearer <token>
# API_SECRET=tu_token_secreto_aqui

# Configuración de correo de alerta (se envía cuando las credenciales de ChatGPT expiran)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_correo@gmail.com
# SMTP_PASS=tu_app_password
# ALERT_EMAIL_TO=destinatario@email.com
